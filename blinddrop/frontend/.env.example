# Frontend API base URLs
# NEXT_PUBLIC_API_BASE is used by admin/dashboard pages (includes /api suffix)
# NEXT_PUBLIC_API_URL is used by public pages (upload/download — no /api suffix)

# Local development
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Production (HF Spaces) — uncomment and replace with your Space URL
# NEXT_PUBLIC_API_BASE=https://YOUR-USERNAME-blinddrop.hf.space/api
# NEXT_PUBLIC_API_URL=https://YOUR-USERNAME-blinddrop.hf.space
